[app]
title = Cypher
package.name = cypher
package.domain = org.lilpeachbat
source.dir = .
source.include_exts = py,png,jpg,ttf,json
version = 1.0

# IMPORTANT: These are the requirements your app needs to run
requirements = python3,kivy,requests,cryptography,openssl,urllib3,certifi,idna,charset-normalizer

orientation = portrait
fullscreen = 0
android.archs = arm64-v8a
android.allow_backup = True

# Icon and Splash (Make sure these match your filenames)
icon.filename = CYPHER.png

